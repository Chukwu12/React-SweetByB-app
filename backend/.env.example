PORT=5000
DB_STRING=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/YOUR_DB_NAME?retryWrites=true&w=majority&appName=YOUR_APP_NAME
FRONTEND_URL=https://your-frontend-domain.com

# Cloudinary
CLOUDINARY_URL=cloudinary://YOUR_ACCOUNT_ID:YOUR_ACCOUNT_SECRET@YOUR_CLOUD_NAME
API_KEY=YOUR_CLOUDINARY_API_KEY
API_SECRET=YOUR_CLOUDINARY_API_SECRET
CLOUD_NAME=YOUR_CLOUD_NAME

# Session
SESSION_SECRET=YOUR_SECURE_SESSION_SECRET_HERE

# Stripe
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY_HERE

# External APIs
RECIPES_API_KEY=YOUR_RECIPES_API_KEY_HERE
